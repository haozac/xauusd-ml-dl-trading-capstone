*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.cache/
.coverage
coverage.xml
htmlcov/
build/
dist/
*.egg-info/

# =========================================================
# Python virtual environments and local interpreters
# =========================================================
.venv/
.venv-*/
venv/
env/
ENV/
.python-version

# =========================================================
# Jupyter
# =========================================================
.ipynb_checkpoints/
.jupyter/
.jupyter_cache/

# =========================================================
# Environment variables, credentials, and private keys
# =========================================================
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
credentials.json
service-account*.json
secrets/
private/
